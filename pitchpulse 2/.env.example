# ─── Football Data APIs ────────────────────────────────────────────────────────
# Primary: https://www.api-football.com — free tier 100 req/day
API_FOOTBALL_KEY=

# Fallback: https://www.football-data.org — free tier 10 req/min
FOOTBALL_DATA_API_KEY=

# Optional: https://www.sportmonks.com
SPORTMONKS_API_KEY=

# ─── World Cup 2026 API (Phase 1 — PRIMARY for WC data) ──────────────────────
# Sign up FREE at https://www.wc2026api.com — email only, no credit card
# Free tier: 100 req/day — enough for continuous WC coverage at 15-min polls
WC2026_API_KEY=

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_PROJECT_ID=

# ─── Cache / Redis ────────────────────────────────────────────────────────────
# Upstash Redis — https://upstash.com (free tier)
# NOTE: No npm package needed — we use pure REST fetch() calls
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Stream Discovery ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ─── AI Commentary (Phase 1 — Groq replaces Anthropic for commentary) ─────────
# Groq: https://console.groq.com — FREE, 14,400 req/day, ~200ms, no credit card
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192

# OpenRouter fallback (optional): https://openrouter.ai — free models available
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Anthropic (kept for in-app analysis features, NOT used for live commentary)
ANTHROPIC_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PitchPulse

# ─── Deployment ───────────────────────────────────────────────────────────────
# VERCEL_URL=
# VERCEL_ENV=production
