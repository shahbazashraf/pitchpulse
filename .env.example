# ─── Football Data APIs ────────────────────────────────────────────────────────
# Primary: https://www.api-football.com — free tier 100 req/day, Pro 450/min
API_FOOTBALL_KEY=

# Fallback: https://www.football-data.org — free tier 10 req/min
FOOTBALL_DATA_API_KEY=

# Optional: https://www.sportmonks.com
SPORTMONKS_API_KEY=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Paste your Firebase service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# For Cloud Functions environment (path to service account file)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Firebase project ID (used by Firebase Admin)
FIREBASE_PROJECT_ID=

# ─── Cache / Redis ────────────────────────────────────────────────────────────
# Upstash Redis — https://upstash.com (free tier available)
# NOTE: Redis is not used in the current implementation. These variables are kept
# as comments for reference in case caching is added in the future.
#UPSTASH_REDIS_REST_URL=
#UPSTASH_REDIS_REST_TOKEN=

# ─── Stream Discovery ─────────────────────────────────────────────────────────
# YouTube Data API v3 — https://console.cloud.google.com
# Used for official broadcaster stream discovery
YOUTUBE_API_KEY=

# ─── World Cup 2026 API ───────────────────────────────────────────────────────
# https://wc2026api.com — free tier 100 req/day, no credit card
# Powers live WC standings, fixtures, match details
WC2026_API_KEY=

# ─── AI Commentary & News Summaries ──────────────────────────────────────────
# Anthropic Claude — https://www.anthropic.com
# Used for AI match commentary generation from real events
ANTHROPIC_API_KEY=

# Groq Llama‑3 (free tier) — https://groq.com
# Used for: (1) AI match commentary, (2) homepage news AI summaries
# Free tier: 14,400 req/day — enough for both features
# Get key: https://console.groq.com
GROQ_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PitchPulse

# ─── Deployment ───────────────────────────────────────────────────────────────
# Vercel project settings (set automatically on Vercel)
# VERCEL_URL=
# VERCEL_ENV=production
